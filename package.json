{
  "name": "three-low-poly",
  "version": "1.2.1",
  "description": "Low poly modeling for Three.js",
  "author": "Jason Sturges <jason@jasonsturges.com> (https://jasonsturges.com)",
  "homepage": "https://jasonsturges.com/three-low-poly/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonsturges/three-low-poly.git"
  },
  "license": "ISC",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "scope": "jasonsturges"
  },
  "keywords": [
    "three",
    "low-poly",
    "assets",
    "3d"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "host": "vite --config vite.host.config.ts",
    "build:host": "vite build --config vite.host.config.ts",
    "typecheck:host": "tsc --noEmit -p app/tsconfig.json"
  },
  "peerDependencies": {
    "three": ">=0.180.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.1",
    "lil-gui": "^0.21.0",
    "prettier": "^3.9.4",
    "three": "^0.185.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3"
  }
}
